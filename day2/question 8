#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;

    int original = n;
    int rev = 0;
    if (n < 0) n = -n;
    while (n != 0) {
        rev = rev * 10 + (n % 10);
        n /=10;
    }

    if (original < 0) rev = -rev;
    if (original == rev)
        cout << "Number is a palindrome";
    else
        cout << "Number is not a palindrome";

    return 0;
}

