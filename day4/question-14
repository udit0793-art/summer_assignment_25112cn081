#include <iostream>
using namespace std;

int main() {
    int n;
    cout << "Enter n: ";
    cin >> n;

    int first = 0, second = 1, next;

    if (n == 1) {
        cout << "Fibonacci term " << n << " is: " << first;
    } else if (n == 2) {
        cout << "Fibonacci term " << n << " is: " << second;
    } else {
        for (int i = 3; i <= n; i++) {
            next = first + second;
            first = second;
            second = next;
        }
        cout << "Fibonacci term " << n << " is: " << second;
    }

    return 0;
}
