#include <iostream>
#include <cmath>
using namespace std;

int main() {
    int num, original, rem, result = 0;
    cout << "Enter a number: ";
    cin >> num;

    original = num;
    while (num > 0) {
        rem = num % 10;                 
        result += pow(rem, 3);         
        num /= 10;                     
    }

    if (result == original)
        cout << original << " is an Armstrong number.";
    else
        cout << original << " is NOT an Armstrong number.";

    return 0;
}
