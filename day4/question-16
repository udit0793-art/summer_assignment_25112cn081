#include <iostream>
#include <cmath>
using namespace std;

int main() {
    int start, end;
    cout << "Enter start and end of range: ";
    cin >> start >> end;

    cout << "Armstrong numbers between " << start << " and " << end << " are: ";

    for (int num = start; num <= end; num++) {
        int original = num, rem, result = 0;
        while (original > 0) {
            rem = original % 10;
            result += pow(rem, 3);
            original /= 10;
        }
        if (result == num)
            cout << num << " ";
    }

    return 0;
}
